{
  "name": "vivipractice",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:generate": "npm run generate --workspace=@vivipractice/database",
    "db:push": "npm run push --workspace=@vivipractice/database",
    "db:migrate": "npm run migrate --workspace=@vivipractice/database",
    "db:studio": "npm run studio --workspace=@vivipractice/database",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
