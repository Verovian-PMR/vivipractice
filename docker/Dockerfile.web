# Generic Dockerfile for Next.js apps
# Build arg APP_NAME determines which app to build
ARG APP_NAME=dashboard

# Stage 1: Build
FROM node:20-slim AS builder
WORKDIR /app

ARG APP_NAME
ARG NEXT_PUBLIC_API_URL

COPY package.json package-lock.json ./
COPY packages/ ./packages/
COPY apps/${APP_NAME}/ ./apps/${APP_NAME}/
RUN mkdir -p ./apps/${APP_NAME}/public

RUN npm ci

# Build workspace dependencies first
RUN npm run build --workspace=@vivipractice/types
RUN npm run build --workspace=@vivipractice/ui

# NEXT_PUBLIC_* vars must be available at build time
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN npm run build --workspace=@vivipractice/${APP_NAME}

# Stage 2: Production
FROM node:20-slim AS runner
WORKDIR /app

ARG APP_NAME
ENV NODE_ENV=production
ENV APP_NAME=${APP_NAME}
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/${APP_NAME}/.next/standalone ./
COPY --from=builder /app/apps/${APP_NAME}/.next/static ./apps/${APP_NAME}/.next/static
COPY --from=builder /app/apps/${APP_NAME}/public ./apps/${APP_NAME}/public

EXPOSE 3000
CMD node apps/${APP_NAME}/server.js
